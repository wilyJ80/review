@article{Murray_2020,
doi = {10.1088/1361-6404/aba997},
url = {https://doi.org/10.1088/1361-6404/aba997},
year = {2020},
month = {oct},
publisher = {IOP Publishing},
volume = {41},
number = {6},
pages = {065706},
author = {Murray, Andrew James and Cunane, Peter and Harvey, Matthew},
title = {An undergraduate laboratory experiment to build and characterize a thermionic triode for use as an audio amplifier},
journal = {European Journal of Physics},
abstract = {Although largely superseded by transistors for small signal amplification, the thermionic valve (or tube) still finds use in high-fidelity audio amplifiers, in guitar amplifiers and in high-power radio and television transmitters, where their power to size scalability has advantages over solid state devices. In the undergraduate experiments detailed here students construct a triode inside a vacuum chamber, and investigate the effects of different designs on signal gain. The characteristics of their triodes are measured to determine the optimal condition for signal amplification. The triode is then used to amplify an audio signal to determine the frequency response, and they can listen to the results via headphones using an input signal of their choice. This experiment hence introduces students to vacuum technology, to electron beams and to analog electronics.}
}

@article{Murray_2020_2,
doi = {10.1088/1361-6404/aba225},
url = {https://doi.org/10.1088/1361-6404/aba225},
year = {2020},
month = {oct},
publisher = {IOP Publishing},
volume = {41},
number = {6},
pages = {065302},
author = {Murray, Andrew James and Harvey, Matthew},
title = {An undergraduate laboratory experiment to determine the critical point of SF6 using light scattering at selected wavelengths},
journal = {European Journal of Physics},
abstract = {Molecules and atoms that are normally gaseous at room temperature and pressure will liquefy or solidify as their temperature reduces or their pressure increases. In the apparatus detailed here a commercial cell contains pressurized SF6 so that it exists in both gaseous and liquid states, with the density of both being similar at room temperature. The critical point on the phase diagram can then be investigated, by elevating the temperature of the cell so the densities of liquid and gas equalize. Under these conditions light passing through the cell is highly scattered by density fluctuations in the fluid. By measuring the transmitted light as a function of both temperature and wavelength, the critical exponent can be derived and the effects of light scattering with wavelength investigated.}
}

