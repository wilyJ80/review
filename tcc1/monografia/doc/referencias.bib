@article{mishonov,
doi = {10.1088/1361-6404/aad3d7},
url = {https://doi.org/10.1088/1361-6404/aad3d7},
year = {2018},
month = {aug},
publisher = {IOP Publishing},
volume = {39},
number = {6},
pages = {065202},
author = {Mishonov, T M and Petkov, E G and Mihailova, N Zh and Stefanov, A A and Dimitrova, I M and Gourev, V N and Serafimov, N S and Danchev, V I and Varonov, A M},
title = {Simple do-it-yourself experimental set-up for electron charge qe measurement},
journal = {European Journal of Physics},
abstract = {A simple experiment for the electron charge qe measurement is described. The experimental set-up contains standard electronic equipment only and can be built in every high-school lab all around the world with several days’ pocket money budget. It is concluded that it is time such a practice should be included in regular high-school education. The achieved 13% accuracy is comparable to the best student university labs. The measurement is based on Schottky noise generated by a photodiode. Using a criterion of dollar-per-accuracy for the electron charge qe measurement, this is definitely the world’s best educational experiment. An industrial replica can easily be sold across the globe.}
}
