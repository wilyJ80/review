@article{Wadhwa_2022,
doi = {10.1088/1361-6404/ac362e},
url = {https://doi.org/10.1088/1361-6404/ac362e},
year = {2021},
month = {dec},
publisher = {IOP Publishing},
volume = {43},
number = {1},
pages = {015702},
author = {Wadhwa, Ajay},
title = {Study of coefficient of discharge through orifices},
journal = {European Journal of Physics},
abstract = {A physical quantity called coefficient of discharge, defined as the ratio of actual discharge to the theoretical discharge, is of keen interest in the liquid flow through an orifice. We have investigated the discharge coefficient of the liquid (water) flow through orifices of two different shapes namely the circular and the square. We use the basic arrangement in which the water contained in a long vertical pipe, after falling through a height, is allowed to flow out of an orifice located at its bottom. For our experiment, we have used an Arduino based technique to dynamically record the position of the falling water level as a function of time. We compare the values of the coefficient of discharge obtained in this work with those reported earlier using conventional methods.}
}
